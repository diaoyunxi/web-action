{
  "manifest_version": 3,
  "name": "网页操作执行器",
  "version": "1.9.0",
  "description": "在网页中按顺序执行输入、点击、滑动、刷新、等待（含定时等待/随机等待）、选择、脚本、提取、键盘、截屏、HTTP请求、标签页、通知、Cookie、悬停、双击、条件判断、文件上传、变量设置、元素属性、本地存储、页面导航、媒体控制操作，支持重复执行、条件循环、变量、元素拾取和配置导入导出",
  "author": "Web Action Executor",
  "homepage_url": "https://github.com/diaoyunxi/web-action",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "commands",
    "clipboardRead",
    "clipboardWrite",
    "alarms",
    "notifications"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "网页操作执行器",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "execute-operations": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "执行保存的操作"
    },
    "stop-execution": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "停止执行"
    }
  },
  "minimum_chrome_version": "88"
}
