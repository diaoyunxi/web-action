
{
  "manifest_version": 3,
  "name": "网页操作执行器",
  "version": "1.2.1",
  "description": "在网页中按顺序执行输入、点击、滑动、刷新操作，支持重复执行和条件循环",
  "author": "Web Action Executor",
  "homepage_url": "https://github.com/your-repo/web-action-executor",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "网页操作执行器",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "minimum_chrome_version": "88"
}
